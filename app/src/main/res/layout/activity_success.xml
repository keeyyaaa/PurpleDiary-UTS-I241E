<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_purple_light"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:indeterminateTint="@color/text_purple_dark" />

    <TextView
        android:id="@+id/tvLoadingAi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI sedang membaca perasaanmu..."
        android:textColor="@color/text_purple_dark"
        android:textSize="16sp"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:id="@+id/layoutHasilAi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEmojiMood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="80sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Catatan tersimpan!"
            android:textStyle="bold"
            android:textColor="@color/text_purple_dark"
            android:textSize="20sp"
            android:layout_marginBottom="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="30dp">

            <TextView
                android:id="@+id/tvAiQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Quotes akan muncul di sini..."
                android:textColor="#886688"
                android:textSize="16sp"
                android:textStyle="italic"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/btnOK"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OK Lanjut!"
            android:textStyle="bold"
            android:textColor="@color/text_purple_dark"
            android:textSize="18sp"
            android:padding="10dp"/>
    </LinearLayout>

</LinearLayout>